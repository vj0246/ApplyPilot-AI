# ┌─────────────────────────────────────────────────────────────┐
# │  ApplyPilot — Environment Configuration                     │
# │  1. Copy this file:  cp .env.example .env                  │
# │  2. Get free Groq key: console.groq.com (30 seconds)       │
# │  3. Paste key below. Everything else works as-is.          │
# └─────────────────────────────────────────────────────────────┘

# ── AI (FREE — Groq API) ──────────────────────────────────────
# Get your free key at https://console.groq.com → API Keys
# Paste several keys separated by commas to get automatic rotation — the
# moment one hits its rate limit, the next request tries the next key
# instead of falling back to the dumb regex parser:
#   GROQ_API_KEY=gsk_first_key,gsk_second_key,gsk_third_key
GROQ_API_KEY=gsk_your_key_here

# Model options (all free on Groq):
#   llama-3.3-70b-versatile   ← best quality (default)
#   llama-3.1-8b-instant      ← faster, slightly lower quality
GROQ_MODEL=llama-3.3-70b-versatile

# ── Database (auto-created by Docker) ────────────────────────
POSTGRES_USER=applypilot
POSTGRES_PASSWORD=applypilot
POSTGRES_DB=applypilot

# ── Auth ─────────────────────────────────────────────────────
# Generate a strong key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-please-change-in-production-min-32-chars

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Ports (change only if already in use) ────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000
